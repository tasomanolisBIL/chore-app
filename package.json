{
  "name": "chore-app",
  "version": "1.2.4",
  "description": "Office chore management app",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node --watch --no-warnings server/index.js",
    "client:dev": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node --no-warnings server/index.js",
    "electron:preview": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:all": "npm run build && electron-builder -mw",
    "electron:publish": "npm run build && electron-builder --win --publish always",
    "electron:publish:mac": "npm run build && electron-builder --mac --publish always",
    "electron:publish:all": "npm run build && electron-builder -mw --publish always"
  },
  "build": {
    "appId": "com.office.choreapp",
    "productName": "Chore App",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "server/**",
      "electron/**",
      "package.json"
    ],
    "icon": "build-resources/icon.ico",
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build-resources/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "tasomanolisBIL",
      "repo": "chore-app"
    }
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.3",
    "node-cron": "^4.2.1",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@fullcalendar/core": "^6.1.11",
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/react": "^6.1.11",
    "@fullcalendar/timegrid": "^6.1.11",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}